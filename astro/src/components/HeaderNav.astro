---
const base = import.meta.env.BASE_URL;
---
<header>
  <div class="container">
    <div class="nav">
      <a href="#" class="logo" aria-label="Prime Detail">
        <img src={`${base}assets/images/logo/logo2.png`} alt="Logo Prime Detail" loading="eager" decoding="async" fetchpriority="high" />
      </a>
      <img src={`${base}assets/images/gallery/polissage.webp`} alt="Certification Polissage RS7091 Prime Detail Caen" class="cert-badge" loading="eager" decoding="async" />
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#tarifs">Tarifs</a>
        <a href="#process">Déroulé</a>
        <a href="#contact">Contact</a>
        <a href="tel:0656751197" class="nav-call" style="background: #1fa363; color: #fff; font-weight: 600; display: inline-flex; align-items: center; gap: 7px; border-radius: 12px; padding: 0.55rem 0.9rem; box-shadow: 0 2px 8px #1fa36333;">
          <span style="font-size:1.1em;">📞</span> Appeler
        </a>
        <a href="https://wa.me/33656751197" target="_blank" rel="noopener" class="nav-call" style="background: #25d366; color: #fff; font-weight: 600; display: inline-flex; align-items: center; gap: 7px; border-radius: 12px; padding: 0.55rem 0.9rem; box-shadow: 0 2px 8px #25d36633; margin-left: 6px;">
          <span style="font-size:1.1em;">💬</span> WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>
