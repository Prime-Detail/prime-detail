<section id="contact">
  <div class="container">
    <h2>Demandez votre devis personnalisé</h2>
    <p class="section-intro">
      Décrivez votre véhicule et votre objectif: vous recevez un devis clair, structuré et adapté,
      généralement sous 24h.
    </p>

    <div class="contact-inner">
      <div class="contact-info">
        <h3>Coordonnées directes</h3>
        <p><strong>Téléphone :</strong> <a href="tel:0656751197">06 56 75 11 97</a></p>
        <p><strong>Email :</strong> <a href="mailto:primedetailcaen@gmail.com">primedetailcaen@gmail.com</a></p>
        <p><strong>Zone d’intervention :</strong> Caen et alentours.</p>
        <p>
          Indiquez le modèle, l’année, l’état global (intérieur / extérieur) et, si possible, quelques photos.
          Plus les infos sont précises, plus le devis est juste dès le premier échange.
        </p>
      </div>

      <form class="contact-form" id="contact-form" novalidate>
        <div id="quiz-summary-lock" class="quiz-summary-lock" hidden>
          <p class="quiz-summary-title">Récapitulatif de votre estimation</p>
          <p id="quiz-summary-text" class="quiz-summary-text"></p>
          <p id="quiz-summary-warning" class="quiz-summary-warning" hidden></p>
          <p id="quiz-summary-success" class="quiz-summary-success" hidden></p>
          <a id="quiz-summary-edit" class="quiz-summary-edit" href="#tarifs">Modifier mon quiz</a>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="nom">Nom / Prénom</label>
            <input id="nom" type="text" placeholder="Votre nom" required />
          </div>
          <div class="form-group">
            <label for="ville">Ville</label>
            <input id="ville" type="text" placeholder="Caen, Ifs, Hérouville, Deauville, Mondeville..." />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="vehicule">Modèle du véhicule</label>
            <input id="vehicule" type="text" placeholder="Renault Clio 4, Peugeot 3008..." required />
          </div>
          <div class="form-group">
            <label for="prestation">Type de prestation souhaitée</label>
            <select id="prestation">
              <option value="interieur">Nettoyage intérieur</option>
              <option value="carrosserie">Rénovation carrosserie / polissage</option>
              <option value="polish_one_step">Polissage one-step (brillance rapide)</option>
              <option value="polish_two_step">Polissage 2 étapes (coupe + finition)</option>
              <option value="prepa_ceramique">Préparation céramique (correction + préparation)</option>
              <option value="renovation_optiques">Rénovation optiques + protection UV</option>
              <option value="pack">Pack intérieur + extérieur</option>
              <option value="entretien">Forfait entretien</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="message">Détails / message (optionnel)</label>
          <textarea id="message" placeholder="Optionnel : état du véhicule, poils d’animaux, taches, contraintes d’accès, etc."></textarea>
        </div>

        <button type="submit" class="btn-primary" id="contact-submit">Recevoir mes options de contact</button>
        <p id="contact-form-status" class="contact-form-status"></p>
        <div id="contact-actions" class="contact-actions">
          <a id="contact-whatsapp" class="btn-primary" href="#" target="_blank" rel="noopener">Envoyer ma demande pre-remplie sur WhatsApp</a>
          <a id="contact-call" class="btn-primary" href="tel:0656751197">Appeler 06 56 75 11 97</a>
        </div>
      </form>
    </div>
  </div>
</section>
