        <script is:inline>
          // Affiche l'aide correspondant à l'étape active
          function updateTarifStepHelp(step) {
            for (let i = 1; i <= 4; i++) {
              const el = document.getElementById('tarif-help-step-' + i);
              if (el) el.style.display = (i === step) ? '' : 'none';
            }
          }
          // Hook sur le quiz pour détecter l'étape
          document.addEventListener('DOMContentLoaded', function() {
            const quiz = document.getElementById('tarif-quiz');
            if (!quiz) return;
            const observer = new MutationObserver(() => {
              const activeStep = quiz.querySelector('.step.active');
              if (!activeStep) return;
              let stepNum = 1;
              if (activeStep.hasAttribute('data-step')) {
                const ds = activeStep.getAttribute('data-step');
                if (ds === '2') stepNum = 2;
                else if (ds === '3' || ds === 'exterior-level' || ds === 'polish-level') stepNum = 3;
                else if (ds === '4' || ds === 'result') stepNum = 4;
              }
              updateTarifStepHelp(stepNum);
            });
            observer.observe(quiz, { subtree: true, attributes: true, attributeFilter: ['class'] });
            // Initial
            updateTarifStepHelp(1);
          });
        </script>
