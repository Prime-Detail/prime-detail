---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const faqItems = [
  {
    q: 'Quel est le delai pour un devis detailing a Caen ?',
    a: 'Le devis est generalement prepare sous 24h apres reception des informations sur le vehicule et la prestation souhaitee.'
  },
  {
    q: 'Intervenez-vous a domicile autour de Caen ?',
    a: 'Oui, Prime Detail intervient a domicile a Caen et dans les communes voisines selon planning et conditions d acces.'
  },
  {
    q: 'Quelle prestation choisir entre interieur seul et pack complet ?',
    a: 'Si l habitacle est la priorite, le nettoyage interieur seul est adapte. Pour valoriser l ensemble du vehicule, le pack interieur + exterieur est recommande.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---
<BaseLayout
  title="Detailing auto à Caen : intérieur, polissage, packs premium | Prime Detail"
  description="Detailing auto à Caen et alentours (Ifs, Hérouville, Deauville, Mondeville et communes voisines ~20 km) : nettoyage intérieur, polissage carrosserie, packs premium à domicile."
  canonicalPath="detailing-auto-caen"
>
  <main>
    <section>
      <div class="container">
        <h1>Detailing auto à Caen avec Prime Detail</h1>
        <p class="section-intro">
          Prime Detail propose des prestations de detailing automobile à domicile à Caen et dans les communes voisines.
          Objectif : remettre votre véhicule à niveau, avec une finition premium et une méthode rigoureuse.
        </p>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Prestations locales les plus demandées</h2>
        <div class="grid">
          <article class="card">
            <h3>Nettoyage intérieur complet</h3>
            <p>Habitacle, sièges, moquettes, plastiques, vitres intérieures et zones difficiles d’accès.</p>
          </article>
          <article class="card">
            <h3>Polissage carrosserie</h3>
            <p>Correction esthétique, retrait des défauts visuels légers et protection de la peinture.</p>
          </article>
          <article class="card">
            <h3>Pack intérieur + extérieur</h3>
            <p>Solution globale pour retrouver un véhicule propre, valorisé et agréable à l’usage.</p>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Zone d’intervention autour de Caen</h2>
        <p class="section-intro">
          Interventions possibles à Caen, Ifs, Hérouville-Saint-Clair, Deauville, Mondeville et communes voisines (environ 20 km) selon planning.
        </p>
        <p>
          Besoin d’une estimation rapide ?
          <a href={`${base}#contact`}>Demandez un devis</a>
          ou consultez les <a href={`${base}#tarifs`}>tarifs indicatifs</a>.
        </p>
        <!-- Boutons 'Appeler maintenant' et 'Message WhatsApp' supprimés (PR #4) -->
      </div>
    </section>

    <section id="faq-detailing-caen">
      <div class="container">
        <h2>FAQ - Detailing auto a Caen</h2>
        <div class="grid">
          {faqItems.map((item) => (
            <article class="card">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</BaseLayout>
