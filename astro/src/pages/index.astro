---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderNav from '../components/HeaderNav.astro';
import HeroSection from '../components/HeroSection.astro';
import CertificationSection from '../components/CertificationSection.astro';
import IllustrationsSection from '../components/IllustrationsSection.astro';
import VideoSection from '../components/VideoSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import TarifsSection from '../components/TarifsSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import LocalCaseStudiesSection from '../components/LocalCaseStudiesSection.astro';
import ContactSection from '../components/ContactSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LocalFaqSection from '../components/LocalFaqSection.astro';
import GoogleReviewsSection from '../components/GoogleReviewsSection.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
	title="Detailing auto Caen à domicile | +50 avis Google | Prime Detail"
	description="Detailing auto à domicile à Caen : nettoyage intérieur premium, polissage carrosserie et packs complets. Prime Detail, +50 avis Google, devis en 24h."
>
	<HeaderNav />
	<main>
		<HeroSection />
		<CertificationSection />
		<IllustrationsSection />
		<LocalCaseStudiesSection />
		<VideoSection />
		<ServicesSection />
		<TarifsSection />
		<ProcessSection />
		<GoogleReviewsSection />
		<LocalFaqSection />
		<ContactSection />
	</main>
	<SiteFooter />
	<script src={`${base}scripts/hero-ab.js`} defer></script>
	<script src={`${base}scripts/quiz.js`} defer></script>
	<script src={`${base}scripts/contact-media.js`} defer></script>
</BaseLayout>
