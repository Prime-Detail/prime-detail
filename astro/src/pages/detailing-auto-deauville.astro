---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const faqItems = [
  {
    q: 'Proposez-vous du detailing a domicile a Deauville ?',
    a: 'Oui, Prime Detail intervient a domicile a Deauville et dans les communes voisines selon disponibilites et type de prestation.'
  },
  {
    q: 'Comment obtenir un devis rapide a Deauville ?',
    a: 'Vous pouvez appeler directement ou envoyer un message WhatsApp avec le modele, l etat du vehicule et la prestation visee.'
  },
  {
    q: 'Le polissage est-il adapte a tous les vehicules ?',
    a: 'Un diagnostic rapide permet de confirmer le niveau de correction pertinent selon l etat de la carrosserie et le rendu souhaite.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---
<BaseLayout
  title="Detailing auto à Deauville : intérieur, polissage, packs premium | Prime Detail"
  description="Detailing auto à Deauville et alentours : nettoyage intérieur premium, polissage carrosserie et packs complets à domicile. Devis personnalisé rapide."
  canonicalPath="detailing-auto-deauville"
>
  <main>
    <section>
      <div class="container">
        <h1>Detailing auto à Deauville avec Prime Detail</h1>
        <p class="section-intro">
          Prime Detail intervient à Deauville pour des prestations de detailing automobile à domicile.
          Objectif : remettre votre véhicule à niveau avec une finition premium et une méthode soignée.
        </p>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Prestations les plus demandées à Deauville</h2>
        <div class="grid">
          <article class="card">
            <h3>Nettoyage intérieur complet</h3>
            <p>Habitacle, sièges, moquettes, plastiques, vitres intérieures et zones difficiles d’accès.</p>
          </article>
          <article class="card">
            <h3>Polissage carrosserie</h3>
            <p>Correction esthétique, atténuation des défauts visuels légers et protection de la peinture.</p>
          </article>
          <article class="card">
            <h3>Pack intérieur + extérieur</h3>
            <p>Solution globale pour retrouver un véhicule propre, valorisé et agréable à l’usage.</p>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Zone d’intervention autour de Deauville</h2>
        <p class="section-intro">
          Interventions possibles à Deauville et communes voisines selon planning, avec déplacement à domicile.
        </p>
        <p>
          Besoin d’une estimation rapide ?
          <a href={`${base}#contact`}>Demandez un devis</a>
          ou consultez les <a href={`${base}#tarifs`}>tarifs indicatifs</a>.
        </p>
        <p>
          Contact direct:
          <a href="tel:0656751197">Appeler 06 56 75 11 97</a>
          ou
          <a href="https://wa.me/33656751197" target="_blank" rel="noopener">envoyer un message WhatsApp</a>.
        </p>
      </div>
    </section>

    <section id="faq-detailing-deauville">
      <div class="container">
        <h2>FAQ - Detailing auto a Deauville</h2>
        <div class="grid">
          {faqItems.map((item) => (
            <article class="card">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</BaseLayout>
