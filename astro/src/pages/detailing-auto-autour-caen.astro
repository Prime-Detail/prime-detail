---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LOCAL_CITY_PAGES } from '../data/local-cities';
const base = import.meta.env.BASE_URL;

const faqItems = [
  {
    q: 'Intervenez-vous partout autour de Caen ?',
    a: 'Prime Detail intervient dans un rayon d’environ 20 km autour de Caen, selon planning et accessibilité du véhicule.'
  },
  {
    q: 'Quel délai pour un devis ?',
    a: 'Un devis personnalisé est généralement transmis sous 24h après réception des informations du véhicule.'
  },
  {
    q: 'Quelles prestations sont disponibles ?',
    a: 'Nettoyage intérieur detailing, polissage carrosserie et packs complets intérieur + extérieur, avec intervention à domicile.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---
<BaseLayout
  title="Detailing auto autour de Caen (20 km) | Prime Detail"
  description="Detailing auto autour de Caen (20 km) : villes desservies, prestations disponibles, délais de devis et intervention à domicile avec Prime Detail."
  canonicalPath="detailing-auto-autour-caen"
>
  <main>
    <section>
      <div class="container">
        <h1>Villes desservies autour de Caen (environ 20 km)</h1>
        <p class="section-intro">
          Prime Detail intervient à domicile dans les communes proches de Caen pour le nettoyage intérieur,
          le polissage carrosserie et les packs complets. Cette page regroupe toutes les zones couvertes
          et les liens vers les pages locales dédiées.
        </p>
        <p>
          Besoin d'une estimation rapide ?
          <a href={`${base}#contact`}>Demandez votre devis</a>
          ou consultez les <a href={`${base}#tarifs`}>tarifs indicatifs</a>.
        </p>

        <div class="grid">
          <article class="card">
            <h3>Pages principales</h3>
            <ul>
              <li><a href={`${base}detailing-auto-caen`}>Detailing auto à Caen</a></li>
              <li><a href={`${base}detailing-auto-deauville`}>Detailing auto à Deauville</a></li>
            </ul>
          </article>

          <article class="card" style="grid-column: span 2;">
            <h3>Autres villes autour de Caen</h3>
            <ul>
              {LOCAL_CITY_PAGES.map((city) => (
                <li><a href={`${base}detailing-auto/${city.slug}`}>Detailing auto à {city.name}</a></li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Prestations disponibles dans toutes les communes couvertes</h2>
        <div class="grid">
          <article class="card">
            <h3>Nettoyage intérieur detailing</h3>
            <p>Remise à niveau complète de l'habitacle : sièges, moquettes, plastiques, vitres et zones difficiles d'accès.</p>
          </article>
          <article class="card">
            <h3>Polissage carrosserie</h3>
            <p>Correction esthétique et protection de la peinture pour retrouver une carrosserie nette et valorisée.</p>
          </article>
          <article class="card">
            <h3>Packs complets</h3>
            <p>Solution intérieur + extérieur pour un résultat global, avec adaptation selon l'état initial du véhicule.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="faq-local-around-caen">
      <div class="container">
        <h2>FAQ - Detailing auto autour de Caen</h2>
        <div class="grid">
          {faqItems.map((item) => (
            <article class="card">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</BaseLayout>
