---
import { AREA_SERVED_CITIES } from '../data/local-cities';

const GA_MEASUREMENT_ID = 'G-FJBK0MCYPQ';
const META_PIXEL_ID = '1189334119528421';
const META_CAPI_ENDPOINT = import.meta.env.PUBLIC_META_CAPI_ENDPOINT || '';
const base = import.meta.env.BASE_URL;
// Utilise uniquement le CSS du projet (styles.css) comme fallback
import fs from 'node:fs';
const cssPath = path.resolve(process.cwd(), '..', 'styles.css');
let siteCss = '';
try {
  siteCss = fs.readFileSync(cssPath, 'utf-8');
} catch (e) {
  siteCss = '';
}

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: string;
  ogImagePath?: string;
  noindex?: boolean;
}

const {
  title = 'Prime Detail – Detailing Auto Premium à Domicile | Caen',
  description = 'Detailing intérieur et rénovation carrosserie à domicile autour de Caen. Detailer certifié FD Formation. Nettoyage intérieur complet, polissage et packs premium.',
  canonicalPath,
  ogType = 'website',
  ogImagePath = 'assets/images/gallery/apres.jpeg',
  noindex = false
} = Astro.props as Props;

const fallbackSite = new URL('https://prime-detail.github.io/prime-detail/');
const siteUrl = Astro.site ? new URL(Astro.site.toString()) : fallbackSite;

function absoluteUrl(relativeOrPath: string) {
  return new URL(relativeOrPath.replace(/^\//, ''), siteUrl).toString();
}

const canonicalUrl = canonicalPath ? absoluteUrl(canonicalPath) : (Astro.url?.href || siteUrl.toString());
const ogImageUrl = absoluteUrl(ogImagePath);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';

const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl.toString()}#website`,
      url: siteUrl.toString(),
      name: 'Prime Detail',
      inLanguage: 'fr-FR'
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${siteUrl.toString()}#localbusiness`,
      name: 'Prime Detail',
      url: siteUrl.toString(),
      image: ogImageUrl,
      telephone: '+33656751197',
      email: 'primedetailcaen@gmail.com',
      priceRange: '€€',
      areaServed: AREA_SERVED_CITIES.map((city) => ({ '@type': 'City', name: city })),
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Caen',
        addressRegion: 'Normandie',
        addressCountry: 'FR'
      },
      sameAs: [
        'https://wa.me/33656751197',
        siteUrl.toString()
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Prestations detailing',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Nettoyage intérieur automobile' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Rénovation carrosserie et polissage' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Pack intérieur + extérieur' } }
        ]
      }
    }
  ]
};
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />

    <meta name="theme-color" content="#1e5f71" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}assets/images/logo/logo2.png`} />
    <link rel="shortcut icon" href={`${base}assets/images/logo/logo2.png`} />
    <link rel="apple-touch-icon" href={`${base}assets/images/logo/logo2.png`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = window.gtag || gtag;
      gtag('js', new Date());

      var search = window.location && window.location.search ? window.location.search : '';
      var gaDebug = search.indexOf('ga_debug=1') !== -1;
      var gaTest = search.indexOf('ga_test=1') !== -1;

      gtag('config', GA_MEASUREMENT_ID, {
        debug_mode: gaDebug
      });

      if (gaTest) {
        gtag('event', 'ga_test_ping', {
          debug_mode: true,
          non_interaction: true,
          page_location: window.location.href
        });
      }
    </script>

    <!-- Meta Pixel Code -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js' );
      fbq('init', '1459938332209190');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1459938332209190&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->

    <script is:inline define:vars={{ META_CAPI_ENDPOINT }}>
      window.__META_CAPI_ENDPOINT__ = META_CAPI_ENDPOINT;
    </script>
    <script is:inline>
      window.__metaCapiSend = function (eventData) {
        var endpoint = window.__META_CAPI_ENDPOINT__ || '';
        if (!endpoint || !eventData) {
          return;
        }

        var payload = {
          event_name: eventData.eventName,
          standard_event_name: eventData.standardEventName || '',
          event_id: eventData.eventId || '',
          event_source_url: window.location.href,
          event_time: Math.floor(Date.now() / 1000),
          custom_data: eventData.payload || {}
        };

        try {
          if (typeof navigator !== 'undefined' && typeof navigator.sendBeacon === 'function') {
            var blob = new Blob([JSON.stringify(payload)], { type: 'application/json' });
            if (navigator.sendBeacon(endpoint, blob)) {
              return;
            }
          }
        } catch (error) {
        }

        try {
          fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            keepalive: true
          });
        } catch (error) {
        }
      };
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@500;600;700&display=swap" rel="stylesheet" />
    <style set:html={siteCss}></style>
    <style>
      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      @media (max-width: 640px) {
        body {
          font-size: 1rem;
        }

        h1 {
          font-size: clamp(2rem, 8vw, 2.6rem) !important;
          line-height: 1.15;
        }
      }
    </style>
  </head>
  <body>
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`}
        alt=""
      />
    </noscript>
    <slot />
    <!-- Barre de contact mobile supprimée (PR #4) -->
  </body>
</html>
